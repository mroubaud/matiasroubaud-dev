---
const services = [
  {
    icon: "☁️",
    title: "Cloud Engineering",
    desc: "Diseño y migración de infraestructura a la nube con foco en confiabilidad y costo.",
    points: [
      "Arquitectura en AWS, GCP y Azure",
      "Infraestructura como código (Terraform)",
      "Migraciones y optimización de costos",
      "Contenedores y serverless",
    ],
  },
  {
    icon: "🛢️",
    title: "Data Engineering",
    desc: "Pipelines de datos robustos que alimentan analítica y modelos con datos confiables.",
    points: [
      "Pipelines ETL / ELT y orquestación",
      "Data warehouses & lakehouses",
      "Modelado de datos y calidad (dbt)",
      "Integraciones y APIs de datos",
    ],
  },
  {
    icon: "⚙️",
    title: "IT & Automatización",
    desc: "Soluciones a medida que eliminan trabajo manual y conectan tus sistemas.",
    points: [
      "Automatización de procesos",
      "CI/CD y prácticas DevOps",
      "Integración de herramientas y SaaS",
      "Consultoría técnica y soporte",
    ],
  },
];
---

<section id="servicios">
  <div class="container">
    <span class="eyebrow">Servicios</span>
    <h2 class="section-title">En qué te puedo ayudar</h2>
    <p class="section-intro">
      Trabajo de punta a punta: desde la arquitectura hasta la puesta en
      producción. Tres áreas que se complementan para que tus datos y tu
      infraestructura jueguen a favor del negocio.
    </p>

    <div class="grid">
      {services.map((s) => (
        <article class="card">
          <div class="card-icon">{s.icon}</div>
          <h3>{s.title}</h3>
          <p class="card-desc">{s.desc}</p>
          <ul>
            {s.points.map((p) => <li>{p}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
    margin-top: 48px;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 30px 26px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: var(--accent);
  }

  .card-icon {
    font-size: 1.8rem;
    width: 56px;
    height: 56px;
    display: grid;
    place-items: center;
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: 14px;
    margin-bottom: 18px;
  }

  .card h3 {
    font-size: 1.25rem;
    margin-bottom: 10px;
  }

  .card-desc {
    color: var(--text-muted);
    font-size: 0.96rem;
    margin-bottom: 18px;
  }

  .card ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  .card li {
    position: relative;
    padding-left: 24px;
    font-size: 0.92rem;
    color: var(--text-muted);
  }

  .card li::before {
    content: "›";
    position: absolute;
    left: 6px;
    color: var(--accent);
    font-weight: 700;
  }

  @media (max-width: 880px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
