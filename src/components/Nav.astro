---
import { getTranslations, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getTranslations(lang);

const esHref = "/";
const enHref = "/en/";
---

<header class="nav">
  <div class="container nav-inner">
    <a href="#top" class="brand">
      <span class="brand-mark">MR</span>
      <span class="brand-text">Matías Roubaud</span>
    </a>

    <nav class="nav-links" aria-label="Navegación principal">
      {t.nav.links.map((l) => <a href={l.href}>{l.label}</a>)}
    </nav>

    <div class="nav-right">
      <div class="lang-switch" role="group" aria-label="Idioma">
        <a href={esHref} class:list={["lang", { active: lang === "es" }]} aria-current={lang === "es"}>ES</a>
        <span class="lang-sep">/</span>
        <a href={enHref} class:list={["lang", { active: lang === "en" }]} aria-current={lang === "en"}>EN</a>
      </div>
      <a href="#contacto" class="btn btn-primary nav-cta">{t.nav.cta}</a>
    </div>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 14, 26, 0.72);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 700;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    font-family: var(--mono);
    font-size: 0.85rem;
    color: #04121a;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
  }

  .nav-links {
    display: flex;
    gap: 28px;
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .nav-links a {
    transition: color 0.15s ease;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .lang-switch {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: var(--mono);
    font-size: 0.82rem;
  }

  .lang {
    color: var(--text-dim);
    transition: color 0.15s ease;
  }

  .lang:hover { color: var(--text); }

  .lang.active {
    color: var(--accent);
    font-weight: 600;
  }

  .lang-sep { color: var(--border); }

  .nav-cta {
    padding: 9px 18px;
    font-size: 0.9rem;
  }

  @media (max-width: 760px) {
    .nav-links { display: none; }
  }

  @media (max-width: 460px) {
    .brand-text { display: none; }
    .nav-cta { display: none; }
  }
</style>
