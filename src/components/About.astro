---
import { Image } from "astro:assets";
import { getTranslations, type Lang } from "../i18n/ui";
import matiasPhoto from "../assets/matias.jpg";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = getTranslations(lang).about;
---

<section id="sobre-mi" class="about">
  <div class="container about-grid">
    <div class="about-copy reveal">
      <div class="about-header">
        <figure class="avatar">
          <Image
            src={matiasPhoto}
            alt="Matías Roubaud"
            width={320}
            quality={82}
            format="webp"
            loading="lazy"
          />
        </figure>
        <div>
          <span class="eyebrow">{t.eyebrow}</span>
          <h2 class="section-title">{t.title}</h2>
        </div>
      </div>
      <p set:html={t.p1} />
      <p set:html={t.p2} />

      <ul class="highlights">
        {t.highlights.map((h) => <li>{h}</li>)}
      </ul>
    </div>

    <div class="about-side">
      <aside class="about-panel reveal" style="--reveal-delay: 120ms">
        <h3>{t.panelTitle}</h3>
        <ol class="steps">
          {t.steps.map((s) => (
            <li>
              <span class="step-n">{s.n}</span>
              <div>
                <strong>{s.title}</strong>
                <p>{s.desc}</p>
              </div>
            </li>
          ))}
        </ol>
      </aside>
    </div>
  </div>
</section>

<style>
  .about { background: var(--bg); }

  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 56px;
    align-items: start;
  }

  .about-copy p {
    color: var(--text-muted);
    margin-bottom: 16px;
    font-size: 1.04rem;
  }

  .about-copy :global(strong) { color: var(--text); }

  .highlights {
    list-style: none;
    margin-top: 22px;
    display: grid;
    gap: 12px;
  }

  .highlights li {
    position: relative;
    padding-left: 30px;
    color: var(--text-muted);
    font-size: 0.97rem;
  }

  .highlights li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 700;
  }

  .about-side {
    display: grid;
    gap: 22px;
    position: sticky;
    top: 90px;
  }

  .about-header {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .about-header .section-title {
    margin-bottom: 0;
  }

  .avatar {
    flex-shrink: 0;
    margin: 0;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    overflow: hidden;
    padding: 2px;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.35), 0 0 18px var(--accent-glow);
  }

  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 4%;
    transform: scale(1.06);
    border-radius: 50%;
    display: block;
  }

  .about-panel {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 30px 28px;
  }

  .about-panel h3 {
    font-size: 1.15rem;
    margin-bottom: 22px;
  }

  .steps {
    list-style: none;
    display: grid;
    gap: 22px;
  }

  .steps li {
    display: flex;
    gap: 16px;
  }

  .step-n {
    font-family: var(--mono);
    font-size: 0.82rem;
    color: var(--accent);
    padding-top: 2px;
  }

  .steps strong { display: block; margin-bottom: 2px; }
  .steps p { color: var(--text-dim); font-size: 0.9rem; }

  @media (max-width: 880px) {
    .about-grid { grid-template-columns: 1fr; gap: 36px; }
    .about-side { position: static; }
  }
</style>
